<group name="ot-sentinel,iec104,reconnaissance,tracker">
<!--
  Rule: OT-SENTINEL-IEC-004a (Parent)
  Protocol: IEC 60870-5-104
  Attack Pattern: General Interrogation — Parent Tracker
  Severity: 0 (tracking only)
  Author: Subhash Bharadwaj
  Version: 1.0
  Date: 2026-05-28

  Purpose:
  Tracks General Interrogation (GI) commands (ASDU type 100: C_IC_NA).
  GI requests ask the RTU to report ALL its data points — a complete
  system inventory. Legitimate uses: initial SCADA connection, system
  recovery. Malicious use: reconnaissance before an attack.

  Dependencies:
  - Decoder: iec104_decoder.xml
  - Child rule: 200026 (OT-SENTINEL-IEC-004b)
-->
<rule id="200025" level="0" noalert="1">
  <decoded_as>json</decoded_as>
  <field name="apdu_type" type="pcre2">.*</field>

  
  <!-- ASDU type 100 = C_IC_NA (Interrogation Command) -->
  <field name="asdu_type_id" type="pcre2">^100$</field>
  <field name="event_type" type="pcre2">^request$</field>

  <description>OT Sentinel: IEC 104 General Interrogation request (tracking only)</description></rule>


<!--
  Rule: OT-SENTINEL-IEC-004b (Child)
  Protocol: IEC 60870-5-104
  Attack Pattern: General Interrogation Abuse
  ATT&CK for ICS: T0846 - Remote System Discovery
  Severity: Medium (7/15)
  Tested: No (pending lab validation)
  Author: Subhash Bharadwaj
  Version: 1.0
  Date: 2026-05-28

  Description:
  Detects an unusually high frequency of General Interrogation (GI) requests.
  A single GI request causes the RTU to transmit its entire data model —
  potentially thousands of data points. Repeated GI requests are a clear
  reconnaissance pattern: the attacker is mapping the RTU's entire IOA space.

  GI requests should be extremely rare in normal operations:
  - On SCADA startup (once per connection)
  - After communication loss recovery
  - During system commissioning

  Threshold: 3+ GI requests from same source in 10 minutes.

  Dependencies:
  - Decoder: iec104_decoder.xml
  - Parent rule: 200025 (OT-SENTINEL-IEC-004a)
-->
<rule id="200026" level="7">
  <if_matched_sid>200025</if_matched_sid>

   frequency="3" timeframe="600" ignore="10"
  <same_srcip />

  <description>
    OT Sentinel: IEC 104 General Interrogation abuse detected.
    Source: $(source_ip) issued $(frequency) GI requests in 10 minutes.
    GI requests cause the RTU to dump its entire data model — repeated GIs
    indicate reconnaissance mapping of the device's IOA space.
    Target: $(destination_ip):$(destination_port)
  </description>

  <mitre>
    <id>T0846</id>
  </mitre></rule>
</group>
