<group name="ot-sentinel,dnp3,network_discovery,low_severity">
<!--
  Rule: OT-SENTINEL-DNP-006
  Protocol: DNP3 (TCP/UDP, port 20000)
  Attack Pattern: Unknown Data Link Address
  ATT&CK for ICS: T0846 - Remote System Discovery
  Severity: Low (5/15)
  Tested: No (pending lab validation)
  Author: Subhash Bharadwaj
  Version: 1.0
  Date: 2026-05-28

  Description:
  Detects DNP3 traffic involving data link addresses not present in the known
  addresses CDB list. This could indicate:
  - A new device being added to the DNP3 network (legitimate, track it)
  - An attacker's rogue device joining the network
  - A misconfigured RTU with wrong address settings
  - Network scanning/discovery activity

  This rule checks BOTH source and destination data link addresses. DNP3
  addresses are 16-bit identifiers (0-65519 for device addresses, 65520-65535
  reserved).

  Dependencies:
  - Decoder: dnp3_decoder.xml (must be loaded first)
  - CDB List: cdb-lists/known_dnp3_addresses
  - Log source: dnp3_tap.py JSON output to Wazuh agent

  Tuning:
  - Start with empty list for discovery mode
  - Add each discovered legitimate address to the CDB list
  - After learning period, only true rogues will alert
-->
<rule id="200019" level="5">
  <decoded_as>json</decoded_as>

  
  <field name="event_type" type="pcre2">^request$</field>

  <!-- Check both source and destination addresses against known list -->
  <list field="data_link_source" lookup="not_match_key">etc/lists/known_dnp3_addresses</list>

  <description>
    OT Sentinel: Unknown DNP3 data link address detected.
    Source Address: $(data_link_source) ($(source_ip))
    Destination Address: $(data_link_destination) ($(destination_ip))
    Function: $(function_code) ($(function_name))
    This address is not in the known DNP3 device list.
    If legitimate, add to known_dnp3_addresses CDB list.
  </description>

  <mitre>
    <id>T0846</id>
  </mitre></rule>
</group>
