# Auto-detect text files and normalize to LF on commit
* text=auto

# GitHub Linguist — Python tools are utilities, not the main deliverable
*.py linguist-vendored

# Explicitly set line endings
*.xml text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf
*.md text eol=crlf
*.py text eol=crlf
*.json text eol=crlf
*.txt text eol=crlf
*.sh text eol=lf
